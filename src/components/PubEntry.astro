---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import { Icon } from "astro-icon/components";
import { people } from "../data/people";
import { externalLinkAttrs } from "../lib/links";

interface Props {
  entry: CollectionEntry<"pubs">;
  /** Top-of-list heroes are above the fold; eager-load them to help LCP. */
  eager?: boolean;
}

const LINK_ICONS: Record<string, string> = {
  paper: "lucide:file-text",
  pdf: "lucide:file-text",
  arxiv: "lucide:book-open-text",
  code: "lucide:github",
  poster: "lucide:image",
};

const LINK_LABELS: Record<string, string> = {
  paper: "paper",
  pdf: "pdf",
  arxiv: "arXiv",
  code: "code",
  poster: "poster",
};

// Hero assets live in src/assets/images/, named in each pub's `hero` field.
// An .svg hero is inlined raw so its `currentColor` ink follows the theme;
// a raster hero goes through astro:assets <Image>. Trusted build-time content.
const rawSvgs = import.meta.glob<string>("../assets/images/*.svg", {
  query: "?raw",
  import: "default",
  eager: true,
});
const rasterImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/*.{webp,png,jpg,jpeg}",
  { eager: true },
);

const { entry, eager = false } = Astro.props;
const { data } = entry;

const heroPath = data.hero ? `../assets/images/${data.hero}` : null;
const inlineSvg =
  heroPath && data.hero?.endsWith(".svg") ? (rawSvgs[heroPath] ?? null) : null;
const rasterHero =
  heroPath && !data.hero?.endsWith(".svg")
    ? (rasterImages[heroPath]?.default ?? null)
    : null;

const links = Object.entries(data.links ?? {})
  .filter(([, v]) => Boolean(v))
  .map(([key, url]) => ({
    key,
    url: url as string,
    icon: LINK_ICONS[key] ?? "lucide:link",
    label: LINK_LABELS[key] ?? key,
  }));
---

<article
  id={entry.id}
  class="grid grid-cols-[90px_1fr] gap-3 py-5 sm:grid-cols-[160px_1fr] sm:gap-5"
>
  <div class="relative flex aspect-[4/3] self-start items-center justify-center overflow-hidden rounded-md text-[var(--color-fg)] ring-2 ring-[var(--color-accent-ring)] [&>svg]:h-full [&>svg]:w-full">
    {
      inlineSvg ? (
        <Fragment set:html={inlineSvg} />
      ) : rasterHero ? (
        <Image
          src={rasterHero}
          alt={data.title}
          loading={eager ? "eager" : "lazy"}
          fetchpriority={eager ? "high" : "auto"}
          widths={[160, 320, 480]}
          sizes="(min-width: 640px) 160px, 90px"
          class="absolute inset-0 h-full w-full object-cover"
        />
      ) : (
        <Icon
          name="lucide:file-text"
          class="size-10 text-[var(--color-fg-muted)]"
          aria-hidden="true"
        />
      )
    }
  </div>
  <div class="min-w-0">
    <h3 class="font-semibold leading-snug">{data.title}</h3>
    {
      data.authors && data.authors.length > 0 && (
        <p class="mt-1 text-sm leading-relaxed">
          {data.authors.map((a, i) => {
            const url = !a.self ? people[a.name]?.url : undefined;
            const named = url ? (
              <a href={url} {...externalLinkAttrs(url)}>{a.name}</a>
            ) : (
              a.name
            );
            const wrapped = a.self ? <strong>{named}</strong> : named;
            return (
              <>
                {i > 0 && ", "}
                {wrapped}
                {a.equal && <sup>†</sup>}
              </>
            );
          })}
        </p>
      )
    }
    <p class="mt-1 text-sm">
      <em title={data.venue} class:list={[data.venueHighlight && "font-bold not-italic text-[var(--color-emphasis)]"]}>
        {data.venueShort
          ? `${data.venueShort} ${data.date.getUTCFullYear()}`
          : `${data.venue} ${data.date.getUTCFullYear()}`}
      </em>
      {data.track && <span> {data.track}</span>}
      {data.award && <Fragment>{" · "}<span class="font-bold text-[var(--color-emphasis)]">{data.award}</span></Fragment>}
    </p>
    {
      links.length > 0 && (
        <p class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm">
          {links.map((l) => (
            <a
              href={l.url}
              {...externalLinkAttrs(l.url)}
              class="inline-flex items-center gap-1"
            >
              <Icon name={l.icon} class="size-3.5 shrink-0" aria-hidden="true" />
              <span>{l.label}</span>
            </a>
          ))}
        </p>
      )
    }
  </div>
</article>
