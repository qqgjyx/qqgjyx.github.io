---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const heroPath = project.hero ?? `/images/projects/${project.slug}.webp`;
---

<article id={project.slug} class="grid grid-cols-1 gap-5 border-b border-[var(--color-rule)] py-6 md:grid-cols-[40%_1fr] md:gap-6">
  <div class="aspect-video overflow-hidden rounded-md bg-[var(--color-card-bg)]">
    <img
      src={heroPath}
      alt={project.title}
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover"
      onerror={`this.style.display='none';this.parentElement.classList.add('flex','items-center','justify-center','p-3','text-center','text-xs','text-[var(--color-fg-muted)]');this.parentElement.textContent='${project.slug}';`}
    />
  </div>
  <div class="min-w-0">
    <h3 class="text-lg font-semibold leading-snug tracking-tight">{project.title}</h3>
    {project.role && (
      <p class="mt-1 text-sm text-[var(--color-fg-muted)]">{project.role}</p>
    )}
    <p class="mt-2 text-sm">{project.blurb}</p>
    {project.links && project.links.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-x-3 gap-y-1 text-sm">
        {project.links.map((l) => (
          <li><a href={l.href} target="_blank" rel="noopener">{l.label}</a></li>
        ))}
      </ul>
    )}
  </div>
</article>
