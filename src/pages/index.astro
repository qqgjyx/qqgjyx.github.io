---
import { getCollection, getEntry, render } from "astro:content";
import EduRow from "../components/EduRow.astro";
import MiscEntry from "../components/MiscEntry.astro";
import NewsEntry from "../components/NewsEntry.astro";
import PubEntry from "../components/PubEntry.astro";
import SocialLinks from "../components/SocialLinks.astro";
import WorkRow from "../components/WorkRow.astro";
import Base from "../layouts/Base.astro";

const bioEntry = await getEntry("bio", "bio");
if (!bioEntry) throw new Error("Missing src/content/bio.md");
const { Content: BioContent } = await render(bioEntry);

const pubs = (await getCollection("pubs")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const news = (await getCollection("news")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const education = (await getCollection("education")).sort((a, b) =>
  (b.data.start ?? "").localeCompare(a.data.start ?? ""),
);

const work = (await getCollection("work")).sort((a, b) =>
  (b.data.start ?? "").localeCompare(a.data.start ?? ""),
);

const misc = (await getCollection("misc")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base>
  <main class="mx-auto max-w-[860px] px-6 py-12">
    <h1 class="text-3xl font-semibold tracking-tight">Juntang Wang</h1>
    <p class="mt-2 text-sm text-[var(--color-fg-muted)]">
      {bioEntry.data.role}{bioEntry.data.affiliation && ` · ${bioEntry.data.affiliation}`}
    </p>

    <section class="mt-6 grid gap-6 sm:grid-cols-[180px_1fr] sm:gap-8">
      <div>
        {
          bioEntry.data.photo && (
            <img
              src={bioEntry.data.photo}
              alt="Juntang Wang"
              loading="eager"
              decoding="async"
              class="aspect-square w-full rounded-md bg-[var(--color-card-bg)] object-cover"
              data-fallback="JW"
            />
          )
        }
        <SocialLinks />
      </div>
      <div class="min-w-0 bio-body">
        <BioContent />
      </div>
    </section>

    {
      news.length > 0 && (
        <section class="mt-12">
          <h2 class="text-xl font-semibold tracking-tight">News</h2>
          <ul class="mt-3 space-y-1.5">
            {news.map((n) => (
              <NewsEntry item={n} />
            ))}
          </ul>
        </section>
      )
    }

    {
      pubs.length > 0 && (
        <section class="mt-12">
          <h2 class="text-xl font-semibold tracking-tight">
            Selected Publications
          </h2>
          <p class="mt-1 text-xs text-[var(--color-fg-muted)]">
            <sup>†</sup> denotes equal contribution.
          </p>
          <div class="mt-2 divide-y divide-[var(--color-rule)]">
            {pubs.map((p) => (
              <PubEntry pub={p} />
            ))}
          </div>
        </section>
      )
    }

    {
      education.length > 0 && (
        <section class="mt-12">
          <h2 class="text-xl font-semibold tracking-tight">Education</h2>
          <div class="mt-2">
            {education.map((e) => (
              <EduRow entry={e} />
            ))}
          </div>
        </section>
      )
    }

    {
      work.length > 0 && (
        <section class="mt-12">
          <h2 class="text-xl font-semibold tracking-tight">Work Experience</h2>
          <div class="mt-2">
            {work.map((w) => (
              <WorkRow entry={w} />
            ))}
          </div>
        </section>
      )
    }

    {
      misc.length > 0 && (
        <section class="mt-12">
          <h2 class="text-xl font-semibold tracking-tight">Miscellanea</h2>
          <ul class="mt-3 space-y-1.5">
            {misc.map((m) => (
              <MiscEntry item={m} />
            ))}
          </ul>
        </section>
      )
    }

    <p
      class="mt-16 text-center text-[var(--color-fg-muted)]"
      aria-hidden="true"
    >
      ~ · ~
    </p>

    <footer
      class="mt-6 flex flex-wrap items-center justify-between gap-x-4 gap-y-2 text-xs text-[var(--color-fg-muted)]"
    >
      <p>
        © 2026 Juntang Wang · Built with Astro + Catppuccin + Monaspace ·{" "}
        <a href="https://github.com/qqgjyx/qqgjyx.github.io">Source →</a>
      </p>
      <label class="inline-flex cursor-pointer items-center gap-1 select-none">
        <input type="checkbox" id="theme-toggle" class="sr-only" />
        <span aria-hidden="true">☀ / ☾</span>
        <span class="sr-only">Toggle theme</span>
      </label>
    </footer>
  </main>
</Base>

<style is:global>
  .bio-body p { margin-top: 0.75rem; }
  .bio-body p:first-child { margin-top: 0; }
</style>
