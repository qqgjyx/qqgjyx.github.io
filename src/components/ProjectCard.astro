---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const heroPath = project.hero ?? `/images/projects/${project.slug}.webp`;
---

<article
  id={project.slug}
  class="grid grid-cols-1 gap-4 py-5 sm:grid-cols-[160px_1fr] sm:gap-5"
>
  <div
    class="aspect-square overflow-hidden rounded-md bg-[var(--color-card-bg)]"
  >
    <img
      src={heroPath}
      alt={project.title}
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover"
      data-fallback={project.slug}
    />
  </div>
  <div class="min-w-0">
    <p class="leading-snug">
      <strong class="font-semibold">{project.title}</strong>
      {
        project.links && project.links.length > 0 && (
          <span class="text-[var(--color-fg-muted)]">
            {" "}
            {project.links.map((l, i) => (
              <Fragment>
                {i > 0 && " / "}
                {"["}<a href={l.href} target="_blank" rel="noopener">{l.label}</a>{"]"}
              </Fragment>
            ))}
          </span>
        )
      }
    </p>
    {
      project.role && (
        <p class="mt-1 text-sm text-[var(--color-fg-muted)]">
          <em>{project.role}</em>
        </p>
      )
    }
    <p class="mt-2 text-sm">{project.blurb}</p>
  </div>
</article>
