---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"education">;
}

const { entry } = Astro.props;
const { school, degree, start, end, location, logo, url } = entry.data;
const initial = school.charAt(0);
const MONTHS = [
  "Jan",
  "Feb",
  "Mar",
  "Apr",
  "May",
  "Jun",
  "Jul",
  "Aug",
  "Sep",
  "Oct",
  "Nov",
  "Dec",
];
const fmt = (ym: string | undefined) => {
  if (!ym) return "";
  const [y, m] = ym.split("-");
  const idx = parseInt(m ?? "", 10) - 1;
  if (!Number.isFinite(idx) || idx < 0 || idx > 11) return ym;
  return `${MONTHS[idx]} ${y}`;
};
const startFmt = fmt(start);
const endFmt = end ? fmt(end) : "Present";
---

<div class="flex items-start gap-4 py-3">
  <div
    class="flex size-12 shrink-0 items-center justify-center overflow-hidden rounded-md text-lg font-semibold text-[var(--color-fg-muted)]"
  >
    {
      logo ? (
        <Image
          src={logo}
          alt={school}
          loading="lazy"
          widths={[48, 96]}
          sizes="48px"
          class="h-full w-full object-contain"
          data-fallback={initial}
        />
      ) : (
        <span aria-hidden="true">{initial}</span>
      )
    }
  </div>
  <div class="min-w-0 text-sm">
    {
      url ? (
        <a href={url} class="font-semibold">
          {school}
        </a>
      ) : (
        <strong>{school}</strong>
      )
    }
    <div>{degree}</div>
    <div class="text-[var(--color-fg-muted)]">
      {startFmt} – {endFmt}{location ? ` · ${location}` : ""}
    </div>
  </div>
</div>
