---
import { Icon } from "astro-icon/components";
---

<button
  type="button"
  id="theme-toggle"
  aria-label="Toggle color theme"
  class="theme-toggle inline-flex size-8 shrink-0 items-center justify-center rounded-md border border-[var(--color-rule)] text-[var(--color-fg-muted)] hover:bg-[var(--color-card-bg)] hover:text-[var(--color-fg)] focus-visible:bg-[var(--color-card-bg)] focus-visible:text-[var(--color-fg)]"
>
  <Icon name="lucide:sun" class="size-4 theme-icon-sun" aria-hidden="true" />
  <Icon name="lucide:moon" class="size-4 theme-icon-moon" aria-hidden="true" />
</button>

<style is:global>
  /* Only one icon shown per state. */
  :root[data-theme="light"] .theme-icon-moon { display: none; }
  :root[data-theme="dark"] .theme-icon-sun { display: none; }
</style>

<script>
  const btn = document.getElementById("theme-toggle");
  if (btn) {
    btn.addEventListener("click", () => {
      const next =
        document.documentElement.dataset.theme === "dark" ? "light" : "dark";
      document.documentElement.dataset.theme = next;
      try {
        localStorage.setItem("theme", next);
      } catch {
        /* localStorage may be blocked; silently degrade to per-session toggle */
      }
    });
  }
</script>
