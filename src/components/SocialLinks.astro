---
import { SOCIAL_LINKS } from "../consts";
---

<p class="mt-3 text-xs leading-relaxed text-[var(--color-fg-muted)]">
  {
    SOCIAL_LINKS.map((link, i) => (
      <>
        {i > 0 && " / "}
        <a
          href={link.url}
          target={link.url.startsWith("http") || link.url.startsWith("mailto:") ? "_blank" : undefined}
          rel="noopener"
        >
          {link.label}
        </a>
      </>
    ))
  }
</p>
