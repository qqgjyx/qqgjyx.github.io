---
import { Icon } from "astro-icon/components";
import { SOCIAL_LINKS } from "../consts";
---

<ul class="mt-3 flex flex-wrap justify-center gap-0.5">
  {
    SOCIAL_LINKS.map((link) => (
      <li>
        <a
          href={link.url}
          target={link.url.startsWith("http") || link.url.startsWith("mailto:") ? "_blank" : undefined}
          rel="noopener"
          aria-label={link.label}
          title={link.label}
          class="inline-flex size-6 items-center justify-center rounded text-[var(--color-link)] hover:bg-[var(--color-card-bg)] hover:text-[var(--color-link-hover)] focus-visible:bg-[var(--color-card-bg)] focus-visible:text-[var(--color-link-hover)]"
        >
          <Icon name={link.icon} class="size-4" aria-hidden="true" />
        </a>
      </li>
    ))
  }
</ul>
