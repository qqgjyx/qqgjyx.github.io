---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { getCollection, getEntry, render } from "astro:content";
import EduRow from "../components/EduRow.astro";
import NewsEntry from "../components/NewsEntry.astro";
import ProjectEntry from "../components/ProjectEntry.astro";
import PubEntry from "../components/PubEntry.astro";
import SocialLinks from "../components/SocialLinks.astro";
import TeachingRow from "../components/TeachingRow.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import WorkRow from "../components/WorkRow.astro";
import { honors } from "../data/honors";
import { service } from "../data/service";
import { inlineMd } from "../lib/inline-md";
import Base from "../layouts/Base.astro";

const bioEntry = await getEntry("bio", "bio");
if (!bioEntry) throw new Error("Missing src/content/bio.md");
const { Content: BioContent } = await render(bioEntry);

const pubs = (await getCollection("pubs")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const news = (await getCollection("news")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const education = (await getCollection("education")).sort((a, b) => {
  const dateDiff = (b.data.start ?? "").localeCompare(a.data.start ?? "");
  if (dateDiff !== 0) return dateDiff;
  return b.data.school.localeCompare(a.data.school);
});

const work = (await getCollection("work")).sort((a, b) =>
  (b.data.start ?? "").localeCompare(a.data.start ?? ""),
);

const teaching = (await getCollection("teaching")).sort((a, b) =>
  (b.data.start ?? "").localeCompare(a.data.start ?? ""),
);

const projects = (await getCollection("projects")).sort(
  (a, b) => Number(b.data.featured) - Number(a.data.featured),
);

const hasMiscellanea =
  teaching.length > 0 ||
  honors.length > 0 ||
  service.length > 0 ||
  projects.length > 0;

const hasEqualContribution = pubs.some((p) =>
  p.data.authors?.some((a) => a.equal),
);
---

<Base>
  <main class="mx-auto max-w-[860px] px-6 py-12">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <h1 class="text-3xl font-semibold tracking-tight">
          Juntang Wang
          <span class="ml-1.5 text-xl font-normal text-[var(--color-fg-muted)]">王俊棠</span>
        </h1>
        <p class="mt-2 text-sm text-[var(--color-fg-muted)]">
          {bioEntry.data.role}{bioEntry.data.affiliation && ` · ${bioEntry.data.affiliation}`}
        </p>
      </div>
      <ThemeToggle />
    </div>

    <section class="mt-6 grid grid-cols-[100px_1fr] gap-4 sm:grid-cols-[180px_1fr] sm:gap-8">
      <div>
        {
          bioEntry.data.photo && (
            <Image
              src={bioEntry.data.photo}
              alt="Juntang Wang"
              loading="eager"
              widths={[180, 360]}
              sizes="(min-width: 640px) 180px, 100px"
              class="aspect-square w-full rounded-md bg-[var(--color-card-bg)] object-cover ring-2 ring-[var(--color-accent-ring)]"
              data-fallback="JW"
            />
          )
        }
        <SocialLinks />
      </div>
      <div class="min-w-0 bio-body">
        <BioContent />
      </div>
    </section>

    {
      news.length > 0 && (
        <section class="mt-12">
          <h2 class="text-xl font-semibold tracking-tight">
            <span aria-hidden="true" class="mr-1 text-[var(--color-accent-soft)]">§</span>News
          </h2>
          <ul class="mt-3 space-y-1.5">
            {news.map((n) => (
              <NewsEntry item={n} />
            ))}
          </ul>
        </section>
      )
    }

    {
      pubs.length > 0 && (
        <section class="mt-12">
          <h2 class="text-xl font-semibold tracking-tight">
            <span aria-hidden="true" class="mr-1 text-[var(--color-accent-soft)]">§</span>Selected Publications
          </h2>
          {hasEqualContribution && (
            <p class="mt-1 text-xs text-[var(--color-fg-muted)]">
              <sup>†</sup> denotes equal contribution.
            </p>
          )}
          <div class="mt-2">
            {pubs.map((p, i) => (
              <PubEntry pub={p} priority={i < 4} />
            ))}
          </div>
        </section>
      )
    }

    {
      education.length > 0 && (
        <section class="mt-12">
          <h2 class="text-xl font-semibold tracking-tight">
            <span aria-hidden="true" class="mr-1 text-[var(--color-accent-soft)]">§</span>Education
          </h2>
          <div class="mt-2">
            {education.map((e) => (
              <EduRow entry={e} />
            ))}
          </div>
        </section>
      )
    }

    {
      work.length > 0 && (
        <section class="mt-12">
          <h2 class="text-xl font-semibold tracking-tight">
            <span aria-hidden="true" class="mr-1 text-[var(--color-accent-soft)]">§</span>Work Experience
          </h2>
          <div class="mt-2">
            {work.map((w) => (
              <WorkRow entry={w} />
            ))}
          </div>
        </section>
      )
    }

    {
      hasMiscellanea && (
        <section class="mt-12">
          <h2 class="text-xl font-semibold tracking-tight">
            <span aria-hidden="true" class="mr-1 text-[var(--color-accent-soft)]">§</span>Miscellanea
          </h2>

          <div class="mt-4 grid gap-x-4 gap-y-4 sm:grid-cols-[48px_1fr]">
            {projects.length > 0 && (
              <>
                <div class="flex size-12 items-center justify-center rounded-md bg-[var(--color-card-bg)] text-[var(--color-fg-muted)]" title="Projects">
                  <Icon name="lucide:wrench" class="size-5" aria-hidden="true" />
                </div>
                <div class="space-y-1.5">
                  {projects.map((p) => (
                    <ProjectEntry project={p} />
                  ))}
                </div>
              </>
            )}

            {teaching.length > 0 && (
              <>
                <div class="flex size-12 items-center justify-center rounded-md bg-[var(--color-card-bg)] text-[var(--color-fg-muted)]" title="Teaching">
                  <Icon name="lucide:graduation-cap" class="size-5" aria-hidden="true" />
                </div>
                <div class="space-y-1.5">
                  {teaching.map((t) => (
                    <TeachingRow entry={t} />
                  ))}
                </div>
              </>
            )}

            {honors.length > 0 && (
              <>
                <div class="flex size-12 items-center justify-center rounded-md bg-[var(--color-card-bg)] text-[var(--color-fg-muted)]" title="Honors & Awards">
                  <Icon name="lucide:award" class="size-5" aria-hidden="true" />
                </div>
                <div class="space-y-1.5 text-sm">
                  {honors.map((h) => (
                    <div>
                      <Fragment set:html={inlineMd(h.title)} />
                      {h.note && (
                        <span class="text-[var(--color-fg-muted)]"> ({h.note})</span>
                      )}
                    </div>
                  ))}
                </div>
              </>
            )}

            {service.length > 0 && (
              <>
                <div class="flex size-12 items-center justify-center rounded-md bg-[var(--color-card-bg)] text-[var(--color-fg-muted)]" title="Service & Leadership">
                  <Icon name="lucide:users" class="size-5" aria-hidden="true" />
                </div>
                <div class="space-y-1.5 text-sm">
                  {service.map((s) => (
                    <div>
                      <Fragment set:html={inlineMd(s.title)} />
                    </div>
                  ))}
                </div>
              </>
            )}

          </div>
        </section>
      )
    }

    <p
      class="mt-16 text-center text-[var(--color-accent-soft)]"
      aria-hidden="true"
    >
      ~ · ~
    </p>

    <footer class="mt-6 text-xs text-[var(--color-fg-muted)]">
      <p>
        © 2026 Juntang Wang · Built with Astro + Catppuccin + Monaspace ·{" "}
        <a href="https://github.com/qqgjyx/qqgjyx.github.io">Source →</a>
      </p>
    </footer>
  </main>
</Base>

<style is:global>
  .bio-body p { margin-top: 0.75rem; }
  .bio-body p:first-child { margin-top: 0; }
</style>
