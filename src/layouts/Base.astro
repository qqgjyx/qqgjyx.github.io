---
import { Font } from "astro:assets";
import { SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from "../consts";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  noIndex?: boolean;
  lang?: string;
  className?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  ogImage,
  ogType = "website",
  noIndex = false,
  lang = "en",
  className,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE_URL);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.toString()} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical.toString()} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <Font cssVariable="--font-mono" preload />

    <script is:inline>
      // Set initial theme before paint to avoid FOUC. Reads localStorage
      // (user preference, wins) then falls back to OS prefers-color-scheme.
      try {
        const saved = localStorage.getItem("theme");
        const dark = saved
          ? saved === "dark"
          : window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme = dark ? "dark" : "light";
      } catch {
        document.documentElement.dataset.theme = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches
          ? "dark"
          : "light";
      }
    </script>
  </head>
  <body class={className}>
    <slot />
    <script>
      // CSP-friendly image fallback: any <img data-fallback="..."> swaps to a
      // text placeholder containing the fallback string on error. One handler
      // covers every card; no per-element inline JS. Special value "hide"
      // just hides the broken img (used when an icon is rendered behind).
      document.addEventListener(
        "error",
        (event) => {
          const target = event.target;
          if (!(target instanceof HTMLImageElement)) return;
          const label = target.dataset.fallback;
          if (!label) return;
          target.style.display = "none";
          if (label === "hide") return;
          const parent = target.parentElement;
          if (!parent) return;
          parent.classList.add(
            "flex",
            "items-center",
            "justify-center",
            "p-3",
            "text-center",
            "text-xs",
            "text-[var(--color-fg-muted)]",
          );
          parent.textContent = label;
        },
        true,
      );
    </script>
  </body>
</html>
