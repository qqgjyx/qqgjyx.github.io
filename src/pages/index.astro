---
import ProjectCard from "../components/ProjectCard.astro";
import PubCard from "../components/PubCard.astro";
import { archivedProjects } from "../data/archived";
import { education } from "../data/education";
import { links } from "../data/links";
import { news } from "../data/news";
import { projects } from "../data/projects";
import { work } from "../data/work";
import Base from "../layouts/Base.astro";
import { getAllPubs } from "../lib/pubs";

const pubs = getAllPubs();
---

<Base
  title="Juntang Wang"
  description="Personal site of Juntang Wang, AI for Science researcher."
>
  <main class="mx-auto max-w-screen-md px-5 py-12">
    <section id="bio" class="grid gap-6 sm:grid-cols-[1fr_160px] sm:gap-8">
      <div>
        <h1 class="text-3xl font-semibold tracking-tight">Juntang Wang</h1>
        <p class="mt-4">
          Researcher in AI for Science. Current threads: graph and spectral
          methods, manifold-informed learning for medical signals, and
          configuration learning for early cognition. Starting the Harvard MS
          in Data Science, fall 2026.
        </p>
        {
          links.length > 0 && (
            <p class="mt-4 text-sm text-[var(--color-fg-muted)]">
              {links.map((l, i) => (
                <Fragment>
                  {i > 0 && " / "}
                  {"["}<a href={l.url} target="_blank" rel="noopener">{l.label}</a>{"]"}
                </Fragment>
              ))}
            </p>
          )
        }
      </div>
      <div
        class="order-first aspect-square w-32 overflow-hidden rounded-md bg-[var(--color-card-bg)] sm:order-none sm:w-40"
      >
        <img
          src="/images/profile.webp"
          alt="Juntang Wang"
          loading="eager"
          decoding="async"
          class="h-full w-full object-cover"
          data-fallback="JW"
        />
      </div>
    </section>

    {
      news.length > 0 && (
        <section id="news" class="mt-12">
          <h2 class="text-xl font-semibold tracking-tight">News</h2>
          <ul class="mt-3 space-y-2 text-sm">
            {news.map((n) => (
              <li class="flex gap-3">
                <span class="shrink-0 text-[var(--color-fg-muted)] tabular-nums">
                  {n.date}
                </span>
                <span>{n.link ? <a href={n.link}>{n.body}</a> : n.body}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section id="publications" class="mt-12">
      <h2 class="text-xl font-semibold tracking-tight">Publications</h2>
      <div class="mt-2 divide-y divide-[var(--color-rule)]">
        {pubs.map((p) => <PubCard pub={p} />)}
      </div>
    </section>

    {
      projects.length > 0 && (
        <section id="projects" class="mt-12">
          <h2 class="text-xl font-semibold tracking-tight">Projects</h2>
          <div class="mt-2 divide-y divide-[var(--color-rule)]">
            {projects.map((p) => (
              <ProjectCard project={p} />
            ))}
          </div>
        </section>
      )
    }

    {
      education.length > 0 && (
        <section id="education" class="mt-12">
          <h2 class="text-xl font-semibold tracking-tight">Education</h2>
          <ul class="mt-3 space-y-2 text-sm">
            {education.map((e) => (
              <li>
                <span class="font-medium">{e.school}</span>
                <span class="text-[var(--color-fg-muted)]"> · {e.degree}</span>
                <span class="text-[var(--color-fg-muted)]">
                  {" "}
                  · {e.start}
                  {e.end ? `–${e.end}` : ""}
                </span>
                {e.location && (
                  <span class="text-[var(--color-fg-muted)]">
                    {" "}
                    · {e.location}
                  </span>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      work.length > 0 && (
        <section id="work" class="mt-12">
          <h2 class="text-xl font-semibold tracking-tight">Work</h2>
          <ul class="mt-3 space-y-2 text-sm">
            {work.map((w) => (
              <li>
                <span class="font-medium">{w.org}</span>
                <span class="text-[var(--color-fg-muted)]"> · {w.role}</span>
                <span class="text-[var(--color-fg-muted)]">
                  {" "}
                  · {w.start}
                  {w.end ? `–${w.end}` : ""}
                </span>
                {w.location && (
                  <span class="text-[var(--color-fg-muted)]">
                    {" "}
                    · {w.location}
                  </span>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      archivedProjects.length > 0 && (
        <section id="archived" class="mt-12">
          <h2 class="text-xl font-semibold tracking-tight">Archived</h2>
          <ul class="mt-3 space-y-1 text-sm">
            {archivedProjects.map((a) => (
              <li>
                <a href={a.url}>{a.title}</a>
                {a.tagline && (
                  <span class="text-[var(--color-fg-muted)]">
                    {" "}
                    · {a.tagline}
                  </span>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </main>
</Base>
