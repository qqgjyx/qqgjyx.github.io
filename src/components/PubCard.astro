---
import type { Pub } from "../lib/pubs";

interface Props {
  pub: Pub;
}

const { pub } = Astro.props;

type Link = { href: string; label: string };
const links: Link[] = [
  pub.paperurl && { href: pub.paperurl, label: "paper" },
  pub.arxivurl && { href: pub.arxivurl, label: "arxiv" },
  pub.pdfurl && { href: pub.pdfurl, label: "pdf" },
  pub.codeurl && { href: pub.codeurl, label: "code" },
  pub.posterurl && { href: pub.posterurl, label: "poster" },
  pub.slidesurl && { href: pub.slidesurl, label: "slides" },
].filter((l): l is Link => Boolean(l));

const heroPath = `/images/pubs/${pub.anchor}.webp`;
---

<article
  id={pub.anchor}
  class="grid grid-cols-1 gap-4 py-5 sm:grid-cols-[160px_1fr] sm:gap-5"
>
  <div
    class="aspect-square overflow-hidden rounded-md bg-[var(--color-card-bg)]"
  >
    <img
      src={heroPath}
      alt={pub.title}
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover"
      data-fallback={pub.anchor}
    />
  </div>
  <div class="min-w-0">
    <p class="leading-snug">
      <strong class="font-semibold">{pub.title}</strong>
      {
        links.length > 0 && (
          <span class="text-[var(--color-fg-muted)]">
            {" "}
            {links.map((l, i) => (
              <Fragment>
                {i > 0 && " / "}
                {"["}<a href={l.href} target="_blank" rel="noopener">{l.label}</a>{"]"}
              </Fragment>
            ))}
          </span>
        )
      }
    </p>
    {
      pub.displayAuthors && (
        <p class="mt-1 text-sm leading-relaxed" set:html={pub.displayAuthors} />
      )
    }
    <p class="mt-1 text-sm text-[var(--color-fg-muted)]">
      <em>{pub.venueShort ?? pub.venue}</em>
      <span> · {pub.year}</span>
      {pub.track && <span> · {pub.track}</span>}
      {pub.award && (
        <span class="text-[var(--color-accent)]"> · {pub.award}</span>
      )}
    </p>
    {pub.tldr && <p class="mt-2 text-sm">{pub.tldr}</p>}
  </div>
</article>
