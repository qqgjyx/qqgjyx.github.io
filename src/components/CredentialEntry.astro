---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { Icon } from "astro-icon/components";
import { fmtMonth } from "../lib/date";
import { externalLinkAttrs } from "../lib/links";

// Shared row for education + work: logo box + title/subtitle/date line.
interface Props {
  title: string; // school | org
  subtitle: string; // degree | role
  start: string;
  end?: string;
  location?: string;
  logo?: ImageMetadata;
  url?: string;
  icon: string; // lucide fallback when there's no logo
}

const { title, subtitle, start, end, location, logo, url, icon } = Astro.props;
const initial = title.charAt(0);
const startFmt = fmtMonth(start);
const endFmt = end ? fmtMonth(end) : "Present";
---

<div class="flex items-start gap-4 py-3">
  <div
    class:list={[
      "flex size-16 shrink-0 items-center justify-center overflow-hidden rounded-md text-[var(--color-fg-muted)]",
      !logo && "bg-[var(--color-card-bg)]",
    ]}
  >
    {
      logo && logo.format === "svg" ? (
        <img
          src={logo.src}
          alt={title}
          loading="lazy"
          decoding="async"
          width={64}
          height={64}
          class="h-full w-full object-contain"
          data-fallback={initial}
        />
      ) : logo ? (
        <Image
          src={logo}
          alt={title}
          loading="lazy"
          widths={[64, 128]}
          sizes="64px"
          class="h-full w-full object-contain"
          data-fallback={initial}
        />
      ) : (
        <Icon name={icon} class="size-7" aria-hidden="true" />
      )
    }
  </div>
  <div class="min-w-0 text-sm">
    <h3 class="font-semibold">
      {url ? <a href={url} {...externalLinkAttrs(url)}>{title}</a> : title}
    </h3>
    <div>{subtitle}</div>
    <div class="text-[var(--color-fg-muted)]">
      {startFmt} – {endFmt}{location ? ` · ${location}` : ""}
    </div>
  </div>
</div>
